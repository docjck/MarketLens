# Copy this file to .env and fill in your values.

# Optional: The Odds API key for NHL moneyline/totals data
# Get one free at https://the-odds-api.com
ODDS_API_KEY=

# Optional: Shared secret token to protect the API when using the Cloudflare tunnel.
# If set, all requests must include the header: X-API-Token: <your_token>
# Leave blank to disable auth (safe for local-only use).
# Generate a strong token e.g.: python -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN=
